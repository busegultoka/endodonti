<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Endodonti Asistanı</title>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --blue-50:  #E6F1FB;
    --blue-100: #B5D4F4;
    --blue-600: #185FA5;
    --blue-700: #1a6eb5;
    --blue-800: #0C447C;
    --blue-900: #042C53;
    --teal-50:  #E1F5EE;
    --teal-600: #0F6E56;
    --gray-50:  #F1EFE8;
    --gray-100: #D3D1C7;
    --gray-200: #B4B2A9;
    --gray-600: #5F5E5A;
    --red-50:   #FCEBEB;
    --red-600:  #A32D2D;
    --red-border: #F7C1C1;
    --bg:       #f4f7fb;
    --surface:  #ffffff;
    --border:   rgba(0,0,0,0.08);
    --text:     #0C1929;
    --muted:    #5a6a7e;
    --radius:   12px;
    --shadow:   0 1px 4px rgba(12,25,41,0.06);
  }

  body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; font-size: 15px; }

  /* HEADER */
  header { background: var(--blue-800); padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 60px; position: sticky; top: 0; z-index: 100; }
  .logo { display: flex; align-items: center; gap: 12px; }
  .logo-mark { width: 34px; height: 34px; background: rgba(255,255,255,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .logo-name { font-size: 16px; font-weight: 600; color: white; letter-spacing: -0.2px; }
  .logo-sub  { font-size: 11px; color: var(--blue-100); margin-top: 1px; }
  .status-pill { display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.12); border-radius: 20px; padding: 5px 12px; font-size: 12px; color: white; }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: #4ade80; animation: blink 2s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* LAYOUT */
  .layout { display: flex; flex: 1; max-width: 1100px; width: 100%; margin: 0 auto; padding: 1.5rem; gap: 1.5rem; }
  .main-col { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1rem; }
  .side-col  { width: 300px; flex-shrink: 0; }

  /* HERO */
  .hero { background: var(--blue-800); border-radius: var(--radius); padding: 1.5rem; color: white; }
  .hero h2 { font-size: 20px; font-weight: 600; margin-bottom: 6px; letter-spacing: -0.3px; }
  .hero p  { font-size: 13px; color: var(--blue-100); line-height: 1.6; }
  .model-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
  .chip { font-size: 11px; padding: 3px 10px; border-radius: 20px; background: rgba(255,255,255,0.12); color: white; border: 1px solid rgba(255,255,255,0.2); }

  /* QUICK QUESTIONS */
  .section-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
  .quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .quick-btn { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px; font-size: 12.5px; color: var(--text); cursor: pointer; text-align: left; line-height: 1.45; transition: all 0.15s; font-family: inherit; }
  .quick-btn:hover { border-color: var(--blue-600); background: var(--blue-50); color: var(--blue-800); }

  /* INPUT */
  .input-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
  .input-card textarea { width: 100%; border: none; outline: none; resize: none; padding: 14px 16px; font-size: 14px; font-family: inherit; color: var(--text); background: transparent; min-height: 76px; line-height: 1.6; }
  .input-card textarea::placeholder { color: var(--muted); }
  .input-foot { display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border-top: 1px solid var(--border); background: #fafbfc; }
  .input-hint { font-size: 11px; color: var(--muted); }
  .send-btn { display: flex; align-items: center; gap: 7px; padding: 7px 16px; background: var(--blue-700); color: white; border: none; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; transition: background 0.15s; font-family: inherit; }
  .send-btn:hover { background: var(--blue-800); }
  .send-btn:disabled { background: var(--gray-200); cursor: not-allowed; }

  /* LOADING */
  .loading { display: none; align-items: center; gap: 12px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 16px; }
  .spinner { width: 20px; height: 20px; border: 2.5px solid var(--border); border-top-color: var(--blue-600); border-radius: 50%; animation: spin 0.8s linear infinite; flex-shrink: 0; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-size: 13px; color: var(--muted); }

  /* ERROR */
  .error-box { display: none; background: var(--red-50); border: 1px solid var(--red-border); border-radius: var(--radius); padding: 14px 16px; font-size: 13px; color: var(--red-600); }

  /* ANSWER */
  .answer-card { display: none; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
  .answer-head { display: flex; align-items: center; justify-content: space-between; padding: 11px 16px; border-bottom: 1px solid var(--border); background: #f8fafc; }
  .answer-head-left { display: flex; align-items: center; gap: 8px; }
  .answer-icon { width: 26px; height: 26px; background: var(--blue-50); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
  .answer-label { font-size: 13px; font-weight: 600; color: var(--text); }
  .lang-badge { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 10px; }
  .lang-en { background: var(--blue-50); color: var(--blue-800); }
  .lang-tr { background: var(--teal-50); color: var(--teal-600); }
  .answer-head-right { display: flex; align-items: center; gap: 8px; }
  .time-chip { font-size: 11px; color: var(--muted); }
  .tr-btn { font-size: 12px; padding: 4px 11px; background: var(--blue-50); color: var(--blue-800); border: 1px solid var(--blue-100); border-radius: 6px; cursor: pointer; font-family: inherit; transition: all 0.15s; }
  .tr-btn:hover { background: var(--blue-600); color: white; border-color: var(--blue-600); }
  .tr-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .answer-body { padding: 16px; }
  .answer-text { font-size: 14px; line-height: 1.75; color: var(--text); }
  .tr-ing { font-size: 12px; color: var(--muted); font-style: italic; display: none; margin-top: 8px; }
  .pages-row { padding: 10px 16px; border-top: 1px solid var(--border); background: #fafbfc; display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
  .pages-lbl { font-size: 11px; color: var(--muted); font-weight: 600; margin-right: 4px; }
  .page-chip { font-size: 11px; padding: 2px 8px; background: var(--blue-50); color: var(--blue-800); border-radius: 20px; font-weight: 500; }

  /* SIDEBAR — HISTORY */
  .side-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
  .side-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-bottom: 1px solid var(--border); background: #f8fafc; }
  .side-title { font-size: 13px; font-weight: 600; color: var(--text); }
  .clear-btn { font-size: 11px; color: var(--red-600); background: none; border: none; cursor: pointer; font-family: inherit; padding: 2px 6px; border-radius: 4px; }
  .clear-btn:hover { background: var(--red-50); }
  .history-list { max-height: 500px; overflow-y: auto; }
  .history-empty { padding: 24px 14px; text-align: center; font-size: 13px; color: var(--muted); line-height: 1.6; }
  .hist-item { padding: 10px 14px; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.1s; }
  .hist-item:hover { background: var(--blue-50); }
  .hist-item:last-child { border-bottom: none; }
  .hist-q { font-size: 12.5px; color: var(--text); line-height: 1.4; margin-bottom: 3px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .hist-meta { font-size: 11px; color: var(--muted); }

  /* FOOTER */
  footer { text-align: center; padding: 1.2rem; font-size: 11px; color: var(--muted); border-top: 1px solid var(--border); background: var(--surface); }

  @media (max-width: 720px) {
    .layout { flex-direction: column; padding: 1rem; }
    .side-col { width: 100%; }
    .quick-grid { grid-template-columns: 1fr; }
    .hero h2 { font-size: 17px; }
    header { padding: 0 1rem; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-mark">🦷</div>
    <div>
      <div class="logo-name">Endodonti Asistanı</div>
      <div class="logo-sub">RAG + Fine-tuned Mistral-7B</div>
    </div>
  </div>
  <div class="status-pill">
    <span class="dot"></span>
    Sistem Aktif
  </div>
</header>

<div class="layout">

  <!-- ANA KOLON -->
  <div class="main-col">

    <!-- HERO -->
    <div class="hero">
      <h2>Klinik Endodonti Karar Destek Sistemi</h2>
      <p>Endodontik terimler, kök kanal tedavisi protokolleri, irrigasyon, obtürasyon ve klinik tanı sorularını yanıtlar. Sorunuzu Türkçe veya İngilizce sorabilirsiniz.</p>
      <div class="model-chips">
        <span class="chip">Mistral-7B-Instruct-v0.2</span>
        <span class="chip">LoRA Fine-tuned</span>
        <span class="chip">MultiQA FAISS</span>
        <span class="chip">Pathways 3488 sayfa</span>
      </div>
    </div>

    <!-- ÖRNEK SORULAR -->
    <div>
      <div class="section-label">Örnek sorular</div>
      <div class="quick-grid">
       <button class="quick-btn" onclick="setQ('What is the main purpose of EDTA in endodontics?')">
  What is the main purpose of EDTA in endodontics?
</button>
<button class="quick-btn" onclick="setQ('What are the clinical signs of irreversible pulpitis?')">
  What are the clinical signs of irreversible pulpitis?
</button>
<button class="quick-btn" onclick="setQ('How should a clinician manage a separated instrument in the root canal?')">
  How should a clinician manage a separated instrument in the root canal?
</button>
<button class="quick-btn" onclick="setQ('What are the primary objectives of using Sodium Hypochlorite (NaOCl) in endodontics?')">
  What are the primary objectives of using Sodium Hypochlorite (NaOCl) in endodontics?
</button>
<button class="quick-btn" onclick="setQ('Explain the importance of working length determination in endodontics.')">
  Explain the importance of working length determination in endodontics.
</button>
<button class="quick-btn" onclick="setQ('What are the indications for root canal retreatment?')">
  What are the indications for root canal retreatment?
</button>
<button class="quick-btn" onclick="setQ('How does calcium hydroxide work as an intracanal medicament?')">
  How does calcium hydroxide work as an intracanal medicament?
</button>
<button class="quick-btn" onclick="setQ('What is the role of MTA in endodontic treatment?')">
  What is the role of MTA in endodontic treatment?
</button>
      </div>
    </div>

    <!-- SORU GİRİŞİ -->
    <div class="input-card">
      <textarea id="qInput" placeholder="Endodontik sorunuzu buraya yazın..." rows="3"
        onkeydown="if(event.ctrlKey&&event.key==='Enter')ask()"></textarea>
      <div class="input-foot">
        <span class="input-hint">Ctrl + Enter ile gönder</span>
        <button class="send-btn" id="sendBtn" onclick="ask()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Gönder
        </button>
      </div>
    </div>

    <!-- LOADING -->
    <div class="loading" id="loading">
      <div class="spinner"></div>
      <span class="loading-text">Model yanıt üretiyor, lütfen bekleyin...</span>
    </div>

    <!-- HATA -->
    <div class="error-box" id="errBox"></div>

    <!-- YANIT -->
    <div class="answer-card" id="answerCard">
      <div class="answer-head">
        <div class="answer-head-left">
          <div class="answer-icon">💬</div>
          <span class="answer-label">Asistan Yanıtı</span>
          <span class="lang-badge lang-en" id="langBadge">EN</span>
        </div>
        <div class="answer-head-right">
          <span class="time-chip" id="timeChip"></span>
          <button class="tr-btn" id="trBtn" onclick="toggleTr()">🌐 Türkçe</button>
        </div>
      </div>
      <div class="answer-body">
        <p class="answer-text" id="answerText"></p>
        <p class="tr-ing" id="trIng">⏳ Çevriliyor...</p>
      </div>
      <div class="pages-row" id="pagesRow" style="display:none">
        <span class="pages-lbl">Referans sayfalar:</span>
        <div id="pageChips"></div>
      </div>
    </div>

  </div>

  <!-- GEÇMİŞ KOLON -->
  <div class="side-col">
    <div class="side-card">
      <div class="side-head">
        <span class="side-title">📋 Soru Geçmişi</span>
        <button class="clear-btn" onclick="clearHistory()">Temizle</button>
      </div>
      <div class="history-list" id="histList">
        <div class="history-empty">Henüz soru sorulmadı.<br>İlk sorunuzu sorun!</div>
      </div>
    </div>
  </div>

</div>

<footer>
  Endodonti Asistanı &nbsp;·&nbsp; Mistral-7B-Instruct-v0.2 + LoRA &nbsp;·&nbsp; MultiQA FAISS &nbsp;·&nbsp; Pathways Endodontology
</footer>

<script>
  const API_URL = " https://unbeneficial-paris-important.ngrok-free.dev";

  let origText = "", trText = "", isTR = false;
  let history  = JSON.parse(localStorage.getItem("endoHistory") || "[]");

  renderHistory();

  function setQ(q) {
    document.getElementById("qInput").value = q;
    document.getElementById("qInput").focus();
  }

  function show(id, mode="flex") { document.getElementById(id).style.display = mode; }
  function hide(id)              { document.getElementById(id).style.display = "none"; }

  async function ask() {
    const q = document.getElementById("qInput").value.trim();
    if (!q) { alert("Lütfen bir soru girin."); return; }

    origText = ""; trText = ""; isTR = false;
    hide("answerCard"); hide("errBox");
    show("loading");
    document.getElementById("sendBtn").disabled = true;

    try {
      const res  = await fetch(`${API_URL}/sor`, {
        method: "POST",
        headers: { "Content-Type": "application/json", "ngrok-skip-browser-warning": "true" },
        body: JSON.stringify({ soru: q })
      });
      if (!res.ok) throw new Error(`Sunucu hatası: ${res.status}`);
      const data = await res.json();

      origText = data.cevap;
      document.getElementById("answerText").textContent = origText;
      document.getElementById("timeChip").textContent   = `⏱ ${data.sure_sn}s`;

      const badge       = document.getElementById("langBadge");
      badge.textContent = "EN";
      badge.className   = "lang-badge lang-en";
      document.getElementById("trBtn").textContent = "🌐 Türkçe";

      const chips = document.getElementById("pageChips");
      chips.innerHTML = "";
      if (data.retrieved_pages && data.retrieved_pages.length > 0) {
        data.retrieved_pages.forEach(p => {
          const s = document.createElement("span");
          s.className   = "page-chip";
          s.textContent = `Sayfa ${p}`;
          chips.appendChild(s);
        });
        show("pagesRow", "flex");
      } else {
        hide("pagesRow");
      }

      show("answerCard", "block");

      saveHistory(q, origText, data.sure_sn);

    } catch (e) {
      document.getElementById("errBox").textContent = `❌ Bağlantı hatası: ${e.message}. Ngrok URL'ini ve Colab'ın çalıştığını kontrol edin.`;
      show("errBox", "block");
    } finally {
      hide("loading");
      document.getElementById("sendBtn").disabled = false;
    }
  }

  async function toggleTr() {
    const btn    = document.getElementById("trBtn");
    const textEl = document.getElementById("answerText");
    const badge  = document.getElementById("langBadge");
    const trIng  = document.getElementById("trIng");

    if (!isTR) {
      if (trText) { apply(trText, "TR"); return; }
      btn.disabled          = true;
      textEl.style.display  = "none";
      trIng.style.display   = "block";
      try {
        const res  = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(origText)}&langpair=en|tr`);
        const data = await res.json();
        if (data.responseStatus === 200) {
          trText = data.responseData.translatedText;
          apply(trText, "TR");
        } else throw new Error();
      } catch { textEl.style.display = "block"; alert("Çeviri yapılamadı."); }
      finally { btn.disabled = false; trIng.style.display = "none"; }
    } else {
      apply(origText, "EN");
    }
  }

  function apply(text, lang) {
    const textEl = document.getElementById("answerText");
    const badge  = document.getElementById("langBadge");
    const btn    = document.getElementById("trBtn");
    textEl.textContent = text;
    textEl.style.display = "block";
    if (lang === "TR") {
      badge.textContent = "TR"; badge.className = "lang-badge lang-tr";
      btn.textContent = "🌐 İngilizce"; isTR = true;
    } else {
      badge.textContent = "EN"; badge.className = "lang-badge lang-en";
      btn.textContent = "🌐 Türkçe"; isTR = false;
    }
  }

  function saveHistory(q, a, t) {
    history.unshift({ q, a, t, tarih: new Date().toLocaleString("tr-TR") });
    if (history.length > 30) history.pop();
    localStorage.setItem("endoHistory", JSON.stringify(history));
    renderHistory();
  }

  function clearHistory() {
    if (!confirm("Tüm geçmiş silinecek. Emin misiniz?")) return;
    history = [];
    localStorage.removeItem("endoHistory");
    renderHistory();
  }

  function renderHistory() {
    const el = document.getElementById("histList");
    if (!history.length) {
      el.innerHTML = '<div class="history-empty">Henüz soru sorulmadı.<br>İlk sorunuzu sorun!</div>';
      return;
    }
    el.innerHTML = history.map((h, i) => `
      <div class="hist-item" onclick="loadHistory(${i})">
        <div class="hist-q">${escHtml(h.q)}</div>
        <div class="hist-meta">${h.tarih} · ⏱${h.t}s</div>
      </div>`).join("");
  }

  function loadHistory(i) {
    const h = history[i];
    document.getElementById("qInput").value = h.q;
    origText = h.a; trText = ""; isTR = false;
    document.getElementById("answerText").textContent = origText;
    document.getElementById("timeChip").textContent   = `⏱ ${h.t}s`;
    const badge = document.getElementById("langBadge");
    badge.textContent = "EN"; badge.className = "lang-badge lang-en";
    document.getElementById("trBtn").textContent = "🌐 Türkçe";
    hide("pagesRow");
    document.getElementById("answerCard").style.display = "block";
  }

  function escHtml(s) {
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  }
</script>
</body>
</html>
